# App
NODE_ENV=development
PORT=3000

# Postgres (used by docker-compose and Bun.sql via DATABASE_URL)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Set automatically inside compose; override for local (non-docker) runs:
# DATABASE_URL=postgres://app:app@localhost:5432/app
