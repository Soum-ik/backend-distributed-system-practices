# App
NODE_ENV=development
PORT=3000

# Load balancer (Nginx edge port exposed to the host)
LB_PORT=8080

# Auth (change JWT_SECRET in production)
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN_SECONDS=604800

# Postgres (used by docker-compose and Bun.sql via DATABASE_URL)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Set automatically inside compose; override for local (non-docker) runs:
# DATABASE_URL=postgres://app:app@localhost:5432/app
